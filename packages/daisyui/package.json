{
    "name": "@sigx/daisyui",
    "version": "0.4.0",
    "description": "DaisyUI component library for SignalX — beautiful, accessible UI components with full theme support",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./theme": {
            "import": "./dist/theme/index.js",
            "types": "./dist/theme/index.d.ts"
        },
        "./buttons": {
            "import": "./dist/buttons/index.js",
            "types": "./dist/buttons/index.d.ts"
        },
        "./forms": {
            "import": "./dist/forms/index.js",
            "types": "./dist/forms/index.d.ts"
        },
        "./layout": {
            "import": "./dist/layout/index.js",
            "types": "./dist/layout/index.d.ts"
        },
        "./feedback": {
            "import": "./dist/feedback/index.js",
            "types": "./dist/feedback/index.d.ts"
        },
        "./navigation": {
            "import": "./dist/navigation/index.js",
            "types": "./dist/navigation/index.d.ts"
        },
        "./data": {
            "import": "./dist/data/index.js",
            "types": "./dist/data/index.d.ts"
        },
        "./typography": {
            "import": "./dist/typography/index.js",
            "types": "./dist/typography/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": true,
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "build:types": "tsgo --emitDeclarationOnly",
        "dev": "vite build --watch",
        "test": "tsgo --noEmit -p tsconfig.test.json && vitest run",
        "test:watch": "vitest",
        "test:types": "tsgo --noEmit -p tsconfig.test.json",
        "typecheck": "tsgo --noEmit -p tsconfig.test.json"
    },
    "keywords": [
        "SignalX",
        "sigx",
        "daisyui",
        "components",
        "ui",
        "tailwindcss"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/daisyui.git",
        "directory": "packages/daisyui"
    },
    "homepage": "https://github.com/signalxjs/daisyui/tree/main/packages/daisyui",
    "bugs": {
        "url": "https://github.com/signalxjs/daisyui/issues"
    },
    "peerDependencies": {
        "sigx": ">=0.4.0",
        "daisyui": ">=5.0.0",
        "tailwindcss": ">=4.0.0"
    },
    "dependencies": {
        "@sigx/reactivity": "^0.4.0",
        "@sigx/runtime-core": "^0.4.0",
        "@sigx/runtime-dom": "^0.4.0"
    },
    "devDependencies": {
        "@sigx/vite": "^0.4.3",
        "happy-dom": "^20.0.11",
        "sigx": "^0.4.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.3",
        "vitest": "^4.1.1"
    },
    "publishConfig": {
        "access": "public"
    }
}
