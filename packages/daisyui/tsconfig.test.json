{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "rootDir": ".",
        "declaration": false,
        "declarationMap": false,
        "emitDeclarationOnly": false,
        "types": ["vitest/globals"]
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "__tests__/**/*.ts", "__tests__/**/*.tsx"]
}
